# Reference only: export these names from your shell or deployment environment.

# Live LLM configuration
# Set OPENAI_API_URL to an accessible OpenAI-compatible endpoint if direct api.openai.com access is blocked in your region or environment.
OPENAI_API_KEY=
OPENAI_API_URL=https://api.openai.com/v1
PERPLEXITY_API_KEY=
PERPLEXITY_API_URL=https://api.perplexity.ai

# Optional TON MCP configuration
TON_MCP_COMMAND=
TON_MCP_MNEMONIC=
TON_MCP_PRIVATE_KEY=
TON_MCP_CONFIG_PATH=
TON_MCP_NETWORK=

# Optional frontend deployment base path
VITE_APP_BASE=/
